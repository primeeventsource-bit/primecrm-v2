# =============================================================================
# Application
# =============================================================================
APP_NAME="Prime CRM Call Center"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/New_York

# =============================================================================
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# Local Docker values shown below. On Laravel Cloud, the platform injects the
# managed Postgres credentials into the runtime environment automatically;
# do NOT set DB_HOST/DB_PASSWORD in Cloud's UI unless you're pointing at an
# external database. Cloud's managed Postgres requires SSL — the default
# DB_SSLMODE=prefer in config/database.php is sufficient (use `require` if
# you want to fail closed).
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=postgres          # docker-compose service name; Cloud overrides
DB_PORT=5432
DB_DATABASE=crm
DB_USERNAME=crm
DB_PASSWORD=crm
DB_SSLMODE=disable        # local Docker only; on Cloud set to `require`

# Read replica (optional - falls back to primary)
DB_READ_HOST=
DB_READ_USERNAME=
DB_READ_PASSWORD=

# =============================================================================
# Redis (cache, queue, broadcasting, dialer state)
# -----------------------------------------------------------------------------
# Laravel Cloud provides managed Redis (KeyDB) and injects the host/password
# automatically. The phpredis extension is available in Cloud's PHP runtime;
# if you'd rather not depend on the extension, set REDIS_CLIENT=predis
# (predis/predis is already a composer dependency).
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis          # docker-compose service name; Cloud overrides
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_DIALER_DB=2
REDIS_BROADCAST_DB=3

# =============================================================================
# Queue / Horizon
# =============================================================================
QUEUE_CONNECTION=redis
HORIZON_PATH=horizon

# =============================================================================
# Cache & Sessions
# =============================================================================
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480

# =============================================================================
# Broadcasting (Pusher / Soketi)
# -----------------------------------------------------------------------------
# Local Docker uses Soketi (a self-hosted Pusher-compatible WebSocket server)
# at `soketi:6001` over plain HTTP. On Laravel Cloud you have two options:
#   1) Use real Pusher: leave PUSHER_HOST blank and set the cluster + creds.
#      config/broadcasting.php auto-resolves PUSHER_HOST to api-{cluster}.pusher.com.
#   2) Use Laravel Reverb (recommended for Cloud): swap to Reverb and set
#      BROADCAST_CONNECTION=reverb. Reverb runs as a separate Cloud process.
# =============================================================================
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=soketi        # docker-compose service name; on Cloud leave blank for Pusher
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

# =============================================================================
# Telephony - Twilio
# =============================================================================
TELEPHONY_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WEBHOOK_BASE_URL=https://your-domain.com
TWILIO_RECORDING_ENABLED=true
TWILIO_VERIFY_SIGNATURE=true
TWILIO_MACHINE_DETECTION=DetectMessageEnd
# Comma-separated pool of caller IDs for local presence dialing
TWILIO_CALLER_ID_POOL=

# =============================================================================
# Storage
# =============================================================================
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

CALL_RECORDING_DISK=s3
CALL_RECORDING_PATH=recordings
CALL_RECORDING_RETENTION_DAYS=365
CALL_RECORDING_ENCRYPT=true

# =============================================================================
# Payments
# =============================================================================
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# E-Sign
# =============================================================================
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_RSA_PRIVATE_KEY_PATH=

# =============================================================================
# Mail
# =============================================================================
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# Logging
# =============================================================================
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# Octane
# -----------------------------------------------------------------------------
# Default is FrankenPHP (matches Laravel Cloud's runtime). For local Docker
# the Dockerfile installs Swoole and runs `octane:start --server=swoole` —
# uncomment OCTANE_SERVER=swoole below if you're running the Docker stack.
# OCTANE_HTTPS=true causes URL generation to use https; on Cloud, TLS is
# terminated at the edge so set this to true in the Cloud env UI.
# =============================================================================
OCTANE_SERVER=frankenphp
# OCTANE_SERVER=swoole    # local Docker
OCTANE_HTTPS=false
