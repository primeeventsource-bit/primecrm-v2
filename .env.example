# =============================================================================
# Application
# =============================================================================
APP_NAME="Prime CRM Call Center"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000
APP_TIMEZONE=America/New_York

# =============================================================================
# Database (PostgreSQL)
# =============================================================================
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=crm
DB_USERNAME=crm
DB_PASSWORD=crm
DB_SSLMODE=disable

# Read replica (optional - falls back to primary)
DB_READ_HOST=
DB_READ_USERNAME=
DB_READ_PASSWORD=

# =============================================================================
# Redis (cache, queue, broadcasting, dialer state)
# =============================================================================
REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_CACHE_DB=1
REDIS_DIALER_DB=2
REDIS_BROADCAST_DB=3

# =============================================================================
# Queue / Horizon
# =============================================================================
QUEUE_CONNECTION=redis
HORIZON_PATH=horizon

# =============================================================================
# Cache & Sessions
# =============================================================================
CACHE_STORE=redis
SESSION_DRIVER=redis
SESSION_LIFETIME=480

# =============================================================================
# Broadcasting (Pusher / Soketi)
# =============================================================================
BROADCAST_CONNECTION=pusher
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=soketi
PUSHER_PORT=6001
PUSHER_SCHEME=http
PUSHER_APP_CLUSTER=mt1

# =============================================================================
# Telephony - Twilio
# =============================================================================
TELEPHONY_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=
TWILIO_WEBHOOK_BASE_URL=https://your-domain.com
TWILIO_RECORDING_ENABLED=true
TWILIO_VERIFY_SIGNATURE=true
TWILIO_MACHINE_DETECTION=DetectMessageEnd
# Comma-separated pool of caller IDs for local presence dialing
TWILIO_CALLER_ID_POOL=

# =============================================================================
# Storage
# =============================================================================
FILESYSTEM_DISK=s3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

CALL_RECORDING_DISK=s3
CALL_RECORDING_PATH=recordings
CALL_RECORDING_RETENTION_DAYS=365
CALL_RECORDING_ENCRYPT=true

# =============================================================================
# Payments
# =============================================================================
STRIPE_KEY=
STRIPE_SECRET=
STRIPE_WEBHOOK_SECRET=

# =============================================================================
# E-Sign
# =============================================================================
DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_USER_ID=
DOCUSIGN_ACCOUNT_ID=
DOCUSIGN_RSA_PRIVATE_KEY_PATH=

# =============================================================================
# Mail
# =============================================================================
MAIL_MAILER=log
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# =============================================================================
# Logging
# =============================================================================
LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# =============================================================================
# Octane
# =============================================================================
OCTANE_SERVER=swoole
OCTANE_HTTPS=false
