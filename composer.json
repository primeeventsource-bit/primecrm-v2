{
    "name": "prime/crm-callcenter",
    "type": "project",
    "description": "Production-grade CRM for vacation rental call centers",
    "keywords": ["laravel", "crm", "callcenter", "twilio", "predictive-dialer"],
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "laravel/framework": "^11.0",
        "laravel/octane": "^2.3",
        "laravel/horizon": "^5.21",
        "laravel/sanctum": "^4.0",
        "inertiajs/inertia-laravel": "^1.0",
        "tightenco/ziggy": "^2.0",
        "predis/predis": "^2.2",
        "twilio/sdk": "^7.16",
        "spatie/laravel-permission": "^6.0",
        "spatie/laravel-data": "^4.0",
        "spatie/laravel-activitylog": "^4.8",
        "stripe/stripe-php": "^14.0",
        "pusher/pusher-php-server": "^7.2",
        "league/flysystem-aws-s3-v3": "^3.0",
        "ramsey/uuid": "^4.7",
        "league/csv": "^9.11",
        "phpoffice/phpspreadsheet": "^5.0",
        "fakerphp/faker": "^1.23"
    },
    "require-dev": {
        "laravel/pint": "^1.13",
        "laravel/telescope": "^5.0",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.0",
        "pestphp/pest": "^2.30",
        "pestphp/pest-plugin-laravel": "^2.2",
        "phpunit/phpunit": "^10.5",
        "spatie/laravel-ignition": "^2.4"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "test": "pest --parallel",
        "test:load": [
            "k6 run tests/load/k6/agent-session.js",
            "k6 run tests/load/k6/pacing-tick.js",
            "k6 run tests/load/k6/webhook-flood.js"
        ]
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
